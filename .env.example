# Handy Go local development environment

# General
NODE_ENV=development
LOG_LEVEL=info
LOG_FORMAT=combined

# Shared auth/service secrets
JWT_SECRET=dev-jwt-secret
JWT_REFRESH_SECRET=dev-jwt-refresh-secret
SERVICE_KEY=internal-service-key
INTERNAL_SERVICE_KEY=internal-service-key

# Client origins
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:8080
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Infrastructure
MONGODB_URI=mongodb://handygo_app:handygo_app_password@localhost:27017/handygo?authSource=handygo
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Gateway and microservice ports
PORT=3000
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
BOOKING_SERVICE_PORT=3003
MATCHING_SERVICE_PORT=3004
NOTIFICATION_SERVICE_PORT=3005
SOS_SERVICE_PORT=3006

# Service discovery
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
BOOKING_SERVICE_URL=http://localhost:3003
MATCHING_SERVICE_URL=http://localhost:3004
NOTIFICATION_SERVICE_URL=http://localhost:3005
SOS_SERVICE_URL=http://localhost:3006

# Optional third-party integrations
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM_NAME=Handy Go
EMAIL_FROM=noreply@handygo.pk
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
OPENAI_API_KEY=
