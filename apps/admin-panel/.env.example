# Handy Go Admin Panel local environment

# Local API gateway used by the Vite dev server proxy.
VITE_API_BASE_URL=/api

# Legacy compatibility only. The panel should no longer rely on Appwrite.
VITE_APPWRITE_ENDPOINT=http://localhost/v1
VITE_APPWRITE_PROJECT_ID=handygo
VITE_APPWRITE_DATABASE_ID=handy_go_db
